# Copy this file to `.env` in the frontend/ folder for local development,
# or set VITE_API_URL as a build-time environment variable on your hosting
# platform (Vercel/Netlify/etc.) for production builds.

# Base URL of the CipherQ backend API, INCLUDING the /api suffix.
# Local dev (Vite already proxies /api to localhost:5000 too, so this is
# optional locally, but required for a production build):
VITE_API_URL=http://localhost:5000/api

# Production example:
# VITE_API_URL=https://your-backend.onrender.com/api
